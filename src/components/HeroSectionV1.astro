---

<section class="hero" id="hero">
  <!-- Full-bleed video background -->
  <div class="hero__bg">
    <video
      class="hero__bg-gif"
      autoplay
      loop
      muted
      playsinline
      aria-hidden="true"
    >
      <source src="/videos/output.webm" type="video/webm" />
    </video>
    <!-- Dark gradient overlay (bottom-heavy, matching Figma) -->
    <div class="hero__overlay"></div>
  </div>

  <!-- Content layer -->
  <div class="hero__inner">
    <!-- Heading -->
    <div class="hero__heading-wrap">
      <h1 class="hero__heading">
        Protecting People, Property<br />and Assets
      </h1>
    </div>

    <!-- CTA buttons -->
    <div class="hero__ctas">
      <a href="/contact" class="hero__btn hero__btn--red">
        <svg
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
        >
          <path
            d="M5 12H19M19 12L13 6M19 12L13 18"
            stroke="white"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
        Quick Quote
      </a>

      <a href="/contact" class="hero__btn hero__btn--navy">
        <svg
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
        >
          <path
            d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.27h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.87a16 16 0 0 0 6 6l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92Z"
            stroke="white"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
        Request Call Back
      </a>
    </div>
  </div>
</section>

<style>
  /* ── Section shell ──────────────────────────────────────── */
  .hero {
    position: relative;
    width: 100%;
    height: 832px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  /* ── Background GIF ─────────────────────────────────────── */
  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero__bg-gif {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  /* ── Gradient overlay — transparent → semi-dark (bottom) ── */
  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0.1) 0%,
      rgba(0, 0, 0, 0.55) 60%,
      rgba(0, 0, 0, 0.75) 100%
    );
  }

  /* ── Content layer ──────────────────────────────────────── */
  .hero__inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 56px;
    padding: 200px 0;
    width: 100%;
  }

  /* ── Heading ────────────────────────────────────────────── */
  .hero__heading-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
  }

  .hero__heading {
    font-family: "Inter", sans-serif;
    font-weight: 800;
    font-size: 72px;
    line-height: 70px;
    letter-spacing: 0.0028em;
    text-align: center;
    color: #ffffff;
    margin: 0;
    padding: 0 64px;
  }



  /* ── CTA row ────────────────────────────────────────────── */
  .hero__ctas {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: center;
    gap: 32px;
  }

  .hero__btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: "Inter", sans-serif;
    font-weight: 700;
    font-size: 16px;
    line-height: 26px;
    color: #ffffff;
    text-decoration: none;
    border-radius: 12px;
    cursor: pointer;
    transition:
      opacity 180ms ease,
      transform 180ms ease;
    white-space: nowrap;
  }

  .hero__btn:hover {
    opacity: 0.88;
    transform: translateY(-1px);
  }

  .hero__btn--red {
    background-color: #b61f26;
    padding: 10px 24px;
  }

  .hero__btn--navy {
    background-color: #33587d;
    padding: 11px 16px;
  }

  /* ── Responsive ─────────────────────────────────────────── */
  @media (max-width: 1024px) {
    .hero {
      height: 700px;
    }

    .hero__heading {
      font-size: 56px;
      line-height: 60px;
    }
  }

  @media (max-width: 768px) {
    .hero {
      height: 580px;
    }

    .hero__inner {
      gap: 40px;
      padding: 100px 0;
    }

    .hero__heading {
      font-size: 40px;
      line-height: 48px;
      padding: 0 32px;
    }

    .hero__ctas {
      flex-direction: column;
      gap: 16px;
    }
  }

  @media (max-width: 480px) {
    .hero {
      height: 520px;
    }

    .hero__heading {
      font-size: 30px;
      line-height: 36px;
      padding: 0 20px;
    }

    .hero__btn--red,
    .hero__btn--navy {
      width: 100%;
      justify-content: center;
      padding: 12px 20px;
    }

    .hero__ctas {
      width: 100%;
      padding: 0 24px;
    }
  }
</style>


