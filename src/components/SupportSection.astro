---
// Orbis protect content (966:3448) — FIXED
// Figma: Each card = COLUMN layout (icon pill on top, then heading + body below)
// Cards stacked vertically with 72px gap | Left: image 540×594 | Right: cards

const features = [
  {
    heading: "Rapid Deployment",
    subheading:
      "Sentry Units are quick to mobilise and ready to protect sites with minimal disruption to operations.",
    icon: "/vigilant_icons/Vector-25.svg",
  },
  {
    heading: "Flexible Coverage",
    subheading:
      "Ideal for short-term requirements, vacant properties, construction sites, and changing site conditions.",
    icon: "/vigilant_icons/Vector-3.svg",
  },
  {
    heading: "Monitored Protection",
    subheading:
      "Units provide an added layer of visibility and reassurance, backed by responsive on-site support.",
    icon: "/vigilant_icons/camera_red.svg",
  },
];
---

<section class="orbis" id="orbis" aria-label="Supporting Orbis Protect">
  <div class="orbis__inner">
    <!-- Header: centered -->
    <div class="orbis__header">
      <h2 class="orbis__heading">Supporting Orbis Protect</h2>
      <p class="orbis__body">
        Vigilant Security Services is proud to support Orbis Protect, deploying
        their Sentry Units across client sites to deliver reliable, flexible
        protection where it is needed most.
      </p>
    </div>

    <!-- Content: image left | cards right -->
    <div class="orbis__content">
      <!-- Left: Orbis image -->
      <div class="orbis__img-wrap">
        <img
          src="/partners/orbis-bg.png"
          alt="Orbis Protect security deployment"
          class="orbis__img"
        />
      </div>

      <!-- Right: 3 feature cards stacked (each = column: icon → heading → body) -->
      <div class="orbis__cards">
        {
          features.map((f) => (
            <div class="orbis__card">
              {/* Icon pill */}
              <div class="orbis__icon">
                <img
                  src={f.icon}
                  alt=""
                  aria-hidden="true"
                  width="20"
                  height="20"
                  class="orbis__icon-img"
                />
              </div>
              {/* Content block */}
              <div class="orbis__card-content">
                <h3 class="orbis__card-heading">{f.heading}</h3>
                <p class="orbis__card-body">{f.subheading}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .orbis {
    background-color: #ffffff;
    padding: 120px 64px 0;
  }

  .orbis__inner {
    display: flex;
    flex-direction: column;
    gap: 64px;
    max-width: 1152px;
    margin: 0 auto;
    width: 100%;
  }

  /* ── Header ─────────────────────────────────────────────── */
  .orbis__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }

  .orbis__heading {
    font-family: "Inter", sans-serif;
    font-weight: 600;
    font-size: 44px;
    line-height: 52px;
    letter-spacing: -0.0045em;
    color: #33587d;
    text-align: center;
    margin: 0;
  }

  .orbis__body {
    font-family: "Inter", sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 26px;
    color: #323232;
    text-align: center;
    max-width: 700px;
    margin: 0;
  }

  /* ── Content row ────────────────────────────────────────── */
  .orbis__content {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 72px;
    width: 100%;
  }

  /* ── Image ──────────────────────────────────────────────── */
  .orbis__img-wrap {
    width: 540px;
    height: 594px;
    flex-shrink: 0;
    border-radius: 16px;
    overflow: hidden;
  }

  .orbis__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  /* ── Cards column ───────────────────────────────────────── */
  .orbis__cards {
    display: flex;
    flex-direction: column;
    gap: 72px;
    flex: 1;
  }

  /* Each card = COLUMN: icon pill on top, then content below */
  .orbis__card {
    display: flex;
    flex-direction: column;
    gap: 16px;
    align-items: flex-start;
  }

  /* Icon pill — rounded, red tint background */
  .orbis__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 10px;
    border-radius: 9999px;
    background: rgba(182, 31, 38, 0.15);
    flex-shrink: 0;
    width: 40px;
    height: 40px;
  }

  /* Tint the icon SVG to match red brand color #B61F26 */
  .orbis__icon-img {
    width: 20px;
    height: 20px;
    object-fit: contain;
    display: block;
    filter: brightness(0) saturate(100%) invert(18%) sepia(82%) saturate(1200%)
      hue-rotate(340deg) brightness(90%) contrast(95%);
  }

  /* Content: heading + body stacked */
  .orbis__card-content {
    display: flex;
    flex-direction: column;
    gap: 8px;
    width: 100%;
  }

  .orbis__card-heading {
    font-family: "Inter", sans-serif;
    font-weight: 900;
    font-size: 18px;
    line-height: 28px;
    color: #33587d;
    margin: 0;
  }

  .orbis__card-body {
    font-family: "Inter", sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 26px;
    color: #323232;
    margin: 0;
  }

  /* ── Responsive ─────────────────────────────────────────── */
  @media (max-width: 1100px) {
    .orbis__content {
      flex-direction: column;
      gap: 48px;
    }

    .orbis__img-wrap {
      width: 100%;
      height: 360px;
    }

    .orbis__cards {
      gap: 40px;
    }
  }

  @media (max-width: 768px) {
    .orbis {
      padding: 80px 32px 0;
    }

    .orbis__heading {
      font-size: 32px;
      line-height: 40px;
    }

    .orbis__img-wrap {
      height: 280px;
    }

    .orbis__cards {
      gap: 32px;
    }
  }

  @media (max-width: 480px) {
    .orbis {
      padding: 60px 20px 0;
    }
  }
</style>
