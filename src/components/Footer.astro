---
const currentYear = new Date().getFullYear();

const social = [
  {
    src: "/footer/facebook.svg",
    alt: "Facebook",
    href: "https://facebook.com",
  },
  {
    src: "/footer/Instagram.svg",
    alt: "Instagram",
    href: "https://instagram.com",
  },
  {
    src: "/footer/limkedin.svg",
    alt: "LinkedIn",
    href: "https://linkedin.com",
  },
];

// Column 1 — Latest News (title + "Posted …" label)
const news = [
  {
    title: "AI, a game changer",
    href: "/blog/ai-game-changer",
    posted: "Posted September 30th, 2025",
  },
  {
    title: "Company Brochure",
    href: "/blog/brochure",
    posted: "Posted June 30th, 2025",
  },
  {
    title: "Newsletter - Aug-24",
    href: "/blog/newsletter-aug-24",
    posted: "Posted July 30th, 2024",
  },
];

// Column 2 — Helpful Links (regulatory / legal)
const helpfulLinks = [
  { label: "Terms Of Use", href: "/terms" },
  { label: "Privacy Statement", href: "/privacy" },
  { label: "Login", href: "/login" },
  { label: "Modern Slavery Statement", href: "/modern-slavery" },
  { label: "Approved Contractor NSI", href: "/nsi" },
  { label: "Approved Contractor SIA", href: "/sia" },
  { label: "Cookie Policy (UK)", href: "/cookies" },
  { label: "Environmental Policy", href: "/environmental" },
];
---

<footer class="footer">
  <div class="footer-inner">
    <!-- ── Top row ─────────────────────────────────────────── -->
    <div class="footer-top">
      <!-- Brand column -->
      <div class="footer-brand">
        <img
          src="/Logo-3D.jpg"
          alt="Vigilant Security Services"
          class="footer-logo"
          width="219"
          height="70"
        />
        <p class="body-large footer-tagline">
          We deliver proactive, technology driven security solutions for
          business and communities.
        </p>
        <div class="footer-social">
          {
            social.map((s) => (
              <a
                href={s.href}
                aria-label={s.alt}
                class="footer-social-link"
                target="_blank"
                rel="noopener noreferrer"
              >
                <img src={s.src} alt={s.alt} width="24" height="24" />
              </a>
            ))
          }
        </div>
      </div>

      <!-- Col 1: Latest News -->
      <div class="footer-col">
        <div class="footer-col-header">
          <span class="card-title footer-col-title">Latest News</span>
        </div>
        <ul class="footer-links">
          {
            news.map((item) => (
              <li>
                <a href={item.href} class="footer-link-item footer-link-news">
                  <span class="body-regular-left footer-link-text">
                    {item.title}
                  </span>
                  <span class="body-regular-left footer-link-date">
                    {item.posted}
                  </span>
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Col 2: Helpful Links -->
      <div class="footer-col">
        <div class="footer-col-header">
          <span class="card-title footer-col-title">Helpful Links</span>
        </div>
        <ul class="footer-links">
          {
            helpfulLinks.map((link) => (
              <li>
                <a href={link.href} class="footer-link-item">
                  <span class="body-regular-left footer-link-text">
                    {link.label}
                  </span>
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Col 3: Contact Us — informational, no anchor links -->
      <div class="footer-col">
        <div class="footer-col-header">
          <span class="card-title footer-col-title">Contact Us</span>
        </div>
        <div class="footer-contact-block">
          <span class="card-title footer-contact-subhead"
            >Our Registered Office</span
          >
          <address class="footer-address">
            Vigilant Security Services UK Ltd<br />
            AMC Business Centre<br />
            12 Cumberland Avenue<br />
            London, NW10 7QL<br />
            United Kingdom
          </address>
        </div>
        <div class="footer-contact-block">
          <span class="card-title footer-contact-subhead">24hr Control</span>
          <a href="tel:+442071834247" class="body-regular-left footer-phone"
            >+44 (0)20 7183 4247</a
          >
          <a
            href="mailto:info@vigilantsecurityservices.co.uk"
            class="body-regular-left footer-phone"
          >
            info@vigilantsecurityservices.co.uk
          </a>
        </div>
      </div>
    </div>

    <!-- ── Bottom bar — centred copyright only ──────────────── -->
    <div class="footer-bottom">
      <span class="title footer-copy">
        © Vigilant Security Services {currentYear}.
      </span>
    </div>
  </div>
</footer>

<style>
  /* ── Footer shell ──────────────────────────────────────── */
  .footer {
    background-color: #323232;
    width: 100%;
  }

  .footer-inner {
    max-width: 1280px;
    margin-inline: auto;
    padding: 80px 64px 0;
    display: flex;
    flex-direction: column;
  }

  /* ── Top row ───────────────────────────────────────────── */
  .footer-top {
    display: flex;
    align-items: flex-start;
    gap: 64px;
    padding-bottom: 64px;
  }

  /* ── Brand column ──────────────────────────────────────── */
  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 20px;
    flex-shrink: 0;
    max-width: 260px;
  }

  .footer-logo {
    width: 219px;
    height: 70px;
    object-fit: contain;
    display: block;
  }

  .footer-tagline {
    color: #ffffff;
    text-align: left;
    font-size: 15px;
  }

  /* Social icons — gap 20px matches design spacing */
  .footer-social {
    display: flex;
    align-items: center;
    gap: 20px;
    height: 24px;
  }

  .footer-social-link {
    display: flex;
    align-items: center;
    opacity: 0.8;
    transition:
      opacity 180ms ease,
      transform 180ms ease;
  }
  .footer-social-link:hover {
    opacity: 1;
    transform: translateY(-2px);
  }
  .footer-social-link img {
    width: 24px;
    height: 24px;
    display: block;
  }

  /* ── Shared column ─────────────────────────────────────── */
  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 32px; /* Figma: gap between heading and first link */
    flex: 1;
    min-width: 140px;
  }

  /* Column header — Figma: height 28, padding 0 8px */
  .footer-col-header {
    padding: 0 8px;
    display: flex;
    align-items: center;
    min-height: 28px;
  }

  .footer-col-title {
    color: #ffffff;
  }

  /* ── Link list ─────────────────────────────────────────── */
  .footer-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
  }

  /* Standard link row — Figma: padding 4 8, min-height 34 */
  .footer-link-item {
    display: flex;
    flex-direction: column;
    padding: 4px 8px;
    min-height: 34px;
    justify-content: center;
    text-decoration: none;
    border-radius: 6px;
    transition: background 160ms ease;
  }
  .footer-link-item:hover {
    background: rgba(255, 255, 255, 0.08);
  }

  /* News rows: title + "Posted …" stacked, with bottom margin */
  .footer-link-news {
    gap: 2px;
    min-height: auto;
    margin-bottom: 12px;
    justify-content: flex-start;
  }

  .footer-link-text {
    color: #ffffff;
  }

  .footer-link-date {
    color: #d9d9d9;
    font-size: 13px;
  }

  /* ── Contact Us (informational) ────────────────────────── */
  .footer-contact-block {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .footer-contact-subhead {
    color: #ffffff;
    display: block;
  }

  .footer-address {
    font-style: normal;
    font-family: "Inter", sans-serif;
    font-size: 15px;
    line-height: 26px;
    color: #ffffff;
    padding: 0 8px;
  }

  .footer-phone {
    color: #ffffff;
    text-decoration: none;
    padding: 0 8px;
    transition: opacity 160ms ease;
  }
  .footer-phone:hover {
    opacity: 0.75;
  }

  /* ── Bottom bar — centred ──────────────────────────────── */
  .footer-bottom {
    border-top: 1px solid #e2ebf5;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 32px 8px;
    min-height: 84px;
    max-width: 1152px;
    margin-inline: auto;
    width: 100%;
  }

  .footer-copy {
    color: #ffffff;
  }

  /* ── Responsive ────────────────────────────────────────── */
  @media (max-width: 1024px) {
    .footer-inner {
      padding: 64px 40px 0;
    }
    .footer-top {
      flex-wrap: wrap;
      gap: 48px;
    }
    .footer-brand {
      max-width: 100%;
    }
  }

  @media (max-width: 640px) {
    .footer-inner {
      padding: 48px 24px 0;
    }
    .footer-top {
      gap: 36px;
    }
    .footer-bottom {
      min-height: auto;
    }
  }
</style>
