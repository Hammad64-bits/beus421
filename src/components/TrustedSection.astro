---
// Trusted container (641:1970) + certifications (702:597)
// Figma: padding 40px 64px, bg #EEEEEE / #323232

const clients = [
  { src: "/clients/client-1.webp", alt: "Client 1" },
  { src: "/clients/client-2.webp", alt: "Client 2" },
  { src: "/clients/client-3.webp", alt: "Client 3" },
  { src: "/clients/client-4.webp", alt: "Client 4" },
  { src: "/clients/client-5.webp", alt: "Client 5" },
  { src: "/clients/client-6.webp", alt: "Client 6" },
];

const certs = [
  "SIA APPROVED",
  "ISO 9001",
  "ISO 45001",
  "ISO 14001",
  "ALTIUS ACCREDITED",
  "NSI GOLD",
  "PSA APPROVED",
];
---

<!-- ── Trusted Clients marquee ──────────────────────────── -->
<section class="trusted" aria-label="Trusted clients">
  <div class="trusted__inner">
    <div class="trusted__track-wrap">
      <div class="trusted__track">
        {
          /* Double the list for seamless loop */
          [...clients, ...clients, ...clients].map((c) => (
            <div class="trusted__item">
              <img src={c.src} alt={c.alt} class="trusted__logo" />
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<!-- ── Certifications dark bar ─────────────────────────── -->
<section class="certs" aria-label="Certifications">
  <div class="certs__inner">
    {
      certs.map((c) => (
        <div class="certs__item">
          <span class="certs__label">{c}</span>
        </div>
      ))
    }
  </div>
</section>

<style>
  /* ── Trusted container ─────────────────────────────────── */
  .trusted {
    background-color: #eeeeee;
    padding: 40px 64px;
    overflow: hidden;
  }

  .trusted__inner {
    width: 100%;
    overflow: hidden;
  }

  .trusted__track-wrap {
    overflow: hidden;
    width: 100%;
  }

  .trusted__track {
    display: flex;
    align-items: center;
    gap: 64px;
    width: max-content;
    animation: marquee 28s linear infinite;
  }

  .trusted__track:hover {
    animation-play-state: paused;
  }

  .trusted__item {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .trusted__logo {
    height: 52px;
    width: auto;
    max-width: 160px;
    object-fit: contain;
    filter: grayscale(60%);
    opacity: 0.75;
    transition: filter 200ms ease, opacity 200ms ease;
  }

  .trusted__logo:hover {
    filter: grayscale(0%);
    opacity: 1;
  }

  @keyframes marquee {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-33.333%);
    }
  }

  /* ── Certifications bar ────────────────────────────────── */
  .certs {
    background-color: #323232;
    padding: 16px 64px;
  }

  .certs__inner {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    max-width: 1152px;
    margin: 0 auto;
    flex-wrap: wrap;
    gap: 16px;
  }

  .certs__item {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .certs__label {
    font-family: "Inter", sans-serif;
    font-weight: 700;
    font-size: 16px;
    line-height: 26px;
    letter-spacing: 0.05em;
    color: #ffffff;
    white-space: nowrap;
  }

  /* ── Responsive ─────────────────────────────────────────── */
  @media (max-width: 768px) {
    .trusted {
      padding: 32px 24px;
    }

    .certs {
      padding: 16px 24px;
    }

    .certs__inner {
      justify-content: center;
      gap: 12px 24px;
    }

    .certs__label {
      font-size: 13px;
    }
  }
</style>
