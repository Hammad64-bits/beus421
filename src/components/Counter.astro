---
// Stats section — Figma node 767:4102
// padding: 120px 64px 0px, white bg
// Three stats: 20+ Years | 500+ Clients | 24/7 Availability
---

<section class="stats" id="stats" aria-label="Company statistics">
  <div class="stats__inner">
    <!-- Years -->
    <div class="stats__item">
      <div class="stats__number-wrap">
        <span class="stats__number" data-target="20" data-suffix="+">0+</span>
      </div>
      <span class="stats__label">Years</span>
    </div>

    <!-- Divider -->
    <div class="stats__divider" aria-hidden="true"></div>

    <!-- Clients -->
    <div class="stats__item">
      <div class="stats__number-wrap">
        <span class="stats__number" data-target="500" data-suffix="+">0+</span>
      </div>
      <span class="stats__label">Clients</span>
    </div>

    <!-- Divider -->
    <div class="stats__divider" aria-hidden="true"></div>

    <!-- Availability -->
    <div class="stats__item">
      <div class="stats__number-wrap">
        <span class="stats__number stats__number--text">24/7</span>
      </div>
      <span class="stats__label">Availability</span>
    </div>
  </div>
</section>

<style>
  /* ── Section shell ──────────────────────────────────────── */
  .stats {
    background-color: #ffffff;
    padding: 120px 64px 0;
  }

  /* ── Row container ──────────────────────────────────────── */
  .stats__inner {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    max-width: 1152px;
    margin: 0 auto;
    width: 100%;
    padding: 8px 0;
    gap: 32px;
  }

  /* ── Single stat ────────────────────────────────────────── */
  .stats__item {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 4px;
  }

  .stats__number-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
  }

  .stats__number {
    font-family: "Inter", sans-serif;
    font-weight: 600;
    font-size: 44px;
    line-height: 52px;
    letter-spacing: -0.0045em;
    color: #33587d;
  }

  .stats__label {
    font-family: "Inter", sans-serif;
    font-weight: 700;
    font-size: 16px;
    line-height: 26px;
    color: #323232;
    display: block;
    width: 100%;
  }

  /* ── Thin vertical divider ──────────────────────────────── */
  .stats__divider {
    width: 1px;
    height: 52px;
    background-color: #eeeeee;
    flex-shrink: 0;
  }

  /* ── Responsive ─────────────────────────────────────────── */
  @media (max-width: 768px) {
    .stats {
      padding: 80px 32px 0;
    }

    .stats__inner {
      flex-direction: row;
      flex-wrap: wrap;
      justify-content: center;
      gap: 32px;
    }

    .stats__divider {
      display: none;
    }

    .stats__number {
      font-size: 36px;
      line-height: 44px;
    }
  }

  @media (max-width: 480px) {
    .stats {
      padding: 60px 20px 0;
    }

    .stats__inner {
      flex-direction: column;
      align-items: center;
      gap: 24px;
    }

    .stats__item {
      align-items: center;
    }
  }
</style>

<script>
  // Animate counting numbers on scroll-into-view
  (function () {
    function easeOut(t: number) {
      return 1 - (1 - t) * (1 - t);
    }

    function animateCounter(el: Element) {
      const target = parseInt((el as HTMLElement).dataset.target || "0", 10);
      const suffix = (el as HTMLElement).dataset.suffix || "";
      const duration = 2000;
      const startTime = performance.now();

      function tick(now: number) {
        const elapsed = now - startTime;
        const progress = Math.min(elapsed / duration, 1);
        const current = Math.round(easeOut(progress) * target);
        el.textContent = current.toLocaleString() + suffix;
        if (progress < 1) requestAnimationFrame(tick);
      }

      requestAnimationFrame(tick);
    }

    const counters = document.querySelectorAll(
      ".stats__number[data-target]"
    );
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            animateCounter(entry.target);
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.3 }
    );

    counters.forEach((el) => observer.observe(el));
  })();
</script>
