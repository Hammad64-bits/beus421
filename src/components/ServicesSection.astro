---
const services = [
  {
    img: "/service/ticket.svg",
    title: "Security Officers",
    description:
      "Professional event security in London, providing crowd control, access management, and SIA-licensed officers for events of all sizes.",
    url: "/services/event-security",
  },
  {
    img: "/service/camera.svg",
    title: "CCTV Monitoring",
    description:
      "Round-the-clock protection for your construction sites, deterring theft, vandalism and unauthorised access across the UK.",
    url: "/services/construction-security",
  },
  {
    img: "/service/key.svg",
    title: "Keyholding",
    description:
      "Experienced retail security officers who reduce shrinkage, prevent shoplifting, and create a safe shopping environment.",
    url: "/services/retail-security",
  },
  {
    img: "/service/building.svg",
    title: "Concierge & Front of House",
    description:
      "Tailored corporate security solutions protecting your people, assets, and premises with professionalism and discretion.",
    url: "/services/corporate-security",
  },
  {
    img: "/service/paw.svg",
    title: "Support Workers",
    description:
      "Specialist security services for government buildings, hospitals, schools, and other public sector organisations.",
    url: "/services/public-sector",
  },
  {
    img: "/service/house.svg",
    title: "Estate Management",
    description:
      "Sensitive, respectful security solutions for care homes, sheltered housing, and residential developments.",
    url: "/services/care-housing",
  },
  {
    img: "/service/wrentch.svg",
    title: "Technical Services",
    description:
      "Trained lone-worker support and welfare officers ensuring the safety of vulnerable individuals in the community.",
    url: "/services/support-workers",
  },
  {
    img: "/service/camera.svg",
    title: "Cleaning Staff",
    description:
      "Supply, installation, and monitoring of CCTV systems integrated with your wider security strategy.",
    url: "/services/security-cameras",
  },
];
---

<div class="figma-container">
  <div class="flex-col" style="gap: 48px;">

    <!-- Section header -->
    <!-- <div class="flex-col" style="gap: 40px" data-reveal="up">
      <h1 class="heading-2">Services Vigilant Offers</h1>
      <p class="body-regular">
        Our extensive range of security services in the UK is designed to
        address the unique challenges faced by various sectors. Each service is
        delivered by thoroughly vetted, SIA-licensed security officers and
        backed by our commitment to professional excellence
      </p>
    </div> -->

     <div class="flex-row" style="gap: 52px">
    <div class="img-container" data-reveal="left">
      <img
        class="trust-img"
        src="/services-info.webp"
        alt="security cameras image"
      />
    </div>
    <div
      class="flex-col-start"
      style="gap: 40px; max-width: 550px;"
      data-reveal="right"
    >
      <div class="flex-col-start" style="gap: 16px">
        <span
          class="pill-text"
          style="padding: 8px; color: var(--color-primary)"
        >
          Our Expertise
        </span>
        <h1 class="heading-2" style="color: var(--primary-text);">
          What We Do — Our Services
        </h1>
        <p
          class="body-large"
          style="text-align: left; color: var(--primary-text);"
        >
          Our extensive range of security services in the UK is designed to address the unique challenges faced by various sectors. Each service is delivered by thoroughly vetted, SIA-licensed security officers and backed by our commitment to professional excellence 
        </p>
      </div>
     
    </div>
  </div>

    <!-- Cards grid -->
    <div class="services-grid">
      {services.map((s, i) => (
        <a href={s.url} class="service-card" data-reveal="up" data-reveal-delay={i * 70}>

          <!-- Top accent bar -->
          <div class="card-accent-bar"></div>

          <!-- Card inner content -->
          <div class="card-inner">

            <!-- Icon + number row -->
            <div class="card-top-row">
              <div class="service-icon-wrap">
                <img src={s.img} alt={s.title} width="22" height="22" />
              </div>
              <span class="card-number">0{i + 1}</span>
            </div>

            <!-- Heading -->
            <div class="service-heading-row">
              <span class="card-title">{s.title}</span>
            </div>

            <!-- Description -->
            <p class="body-regular service-desc">
              {s.description}
            </p>

            <!-- Show more link -->
            <div class="service-link-row">
              <span class="link-label">Explore service</span>
              <div class="link-arrow">
                <svg width="16" height="16" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                  <path
                    d="M4 10h12M11 5l5 5-5 5"
                    stroke="currentColor"
                    stroke-width="1.8"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              </div>
            </div>

          </div>
        </a>
      ))}
    </div>

    
  </div>
</div>

<style>
  .trust-img {
    width: 518px;
    height: 524px;
    border-radius: 8px;
  }
  /* ── Cards grid ─────────────────────────────────────────── */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    justify-content: center;
  }

  /* ── Card shell ──────────────────────────────────────────── */
  .service-card {
    position: relative;
    display: flex;
    flex-direction: column;
    border-radius: 16px;
    background: #ffffff;
    border: 1px solid rgba(141, 153, 174, 0.2);
    text-decoration: none;
    overflow: hidden;
    box-shadow:
      0 1px 2px rgba(43, 45, 66, 0.04),
      0 4px 12px rgba(43, 45, 66, 0.06);
    transition:
      transform 240ms cubic-bezier(0.34, 1.56, 0.64, 1),
      box-shadow 240ms ease,
      border-color 240ms ease;
  }

  .service-card:hover {
    transform: translateY(-5px);
    border-color: rgba(217, 4, 41, 0.2);
    box-shadow:
      0 4px 12px rgba(43, 45, 66, 0.08),
      0 16px 36px rgba(43, 45, 66, 0.1);
  }

  /* ── Top accent bar (red left-border reveal) ─────────────── */
  .card-accent-bar {
    height: 3px;
    width: 100%;
    background: #d90429;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 320ms cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .service-card:hover .card-accent-bar {
    transform: scaleX(1);
  }

  /* ── Card inner padding ──────────────────────────────────── */
  .card-inner {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 22px;
    flex: 1;
  }

  /* ── Top row: icon + number ──────────────────────────────── */
  .card-top-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  /* ── Icon wrap ───────────────────────────────────────────── */
  .service-icon-wrap {
    width: 44px;
    height: 44px;
    border-radius: 10px;
    background: #edf2f4;
    border: 1px solid rgba(141, 153, 174, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: background 240ms ease, border-color 240ms ease;
  }

  .service-card:hover .service-icon-wrap {
    background: rgba(217, 4, 41, 0.08);
    border-color: rgba(217, 4, 41, 0.2);
  }

  .service-icon-wrap img {
    display: block;
    filter: brightness(0) saturate(100%) invert(13%) sepia(97%) saturate(4996%) hue-rotate(341deg) brightness(90%) contrast(110%);
    transition: filter 240ms ease;
  }

  .service-card:hover .service-icon-wrap img {
    filter: brightness(0) saturate(100%) invert(13%) sepia(97%) saturate(4996%) hue-rotate(341deg) brightness(90%) contrast(110%);
  }

  /* ── Number badge ────────────────────────────────────────── */
  .card-number {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: rgba(141, 153, 174, 0.5);
    transition: color 240ms ease;
  }

  .service-card:hover .card-number {
    color: #d90429;
  }

  /* ── Heading ─────────────────────────────────────────────── */
  .service-heading-row {
    display: flex;
    align-items: center;
  }

  .card-title {
    font-size: 15.5px;
    font-weight: 700;
    line-height: 1.3;
    color: #2b2d42;
    transition: color 240ms ease;
  }

  .service-card:hover .card-title {
    color: #d90429;
  }

  /* ── Description ─────────────────────────────────────────── */
  .service-desc {
    font-size: 13px;
    line-height: 1.65;
    color: #8d99ae;
    text-align: left;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
    margin: 0;
  }

  /* ── "Explore service" row ───────────────────────────────── */
  .service-link-row {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 4px;
    padding-top: 12px;
    border-top: 1px solid #edf2f4;
  }

  .link-label {
    font-size: 12.5px;
    font-weight: 600;
    color: #8d99ae;
    letter-spacing: 0.01em;
    transition: color 240ms ease;
  }

  .service-card:hover .link-label {
    color: #d90429;
  }

  .link-arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: #edf2f4;
    color: #8d99ae;
    margin-left: auto;
    transition: background 240ms ease, color 240ms ease, transform 240ms cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .service-card:hover .link-arrow {
    background: #d90429;
    color: #ffffff;
    transform: translateX(3px);
  }

  .link-arrow svg {
    display: block;
    stroke: currentColor;
  }

  /* ── Responsive ──────────────────────────────────────────── */
  @media (max-width: 1200px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 700px) {
    .services-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
