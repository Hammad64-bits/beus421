---
// Service Section (1160:3964) — pixel perfect
// Figma structure:
//   padding: 120px 64px 0px | white bg
//   inner 1152px: column gap 32px
//     - Header: centered h2 + body
//     - Body row (space-between):
//         Left (layout_OU0XIT): column, hug — "WHAT WE OFFER" label + 4 service rows
//         Right (layout_ZJXAYO): 753px fixed, column gap 56px
//           - 2 rows of 3 tag cards (each row gap 24px, cards 235×280px)
//           - CTA button (red outline, "View All Services")
//
// Service row (layout_Q9HEE1): column, gap 40px, padding 40px 0 0 24px
//   - Icon pill 40×40 (navy 15% bg) + name (bold 700 16px) + arrow (24px)
//   - Divider line 315px × 1px #EEEEEE
// Active row: left border 4px solid #B61F26, padding-left 20px; icon bg rgba(51,88,125,0.15)
//
// Tag cards: 235×280px, borderRadius 12px, shadow 0 4 10 rgba(0,0,0,0.25)
//   background: linear-gradient(180deg, rgba(102,102,102,0) 70%, rgba(51,88,125,1) 78%)
//              + real background image /services/service-card-bg.png (cover)
//   Text: Inter Medium 500 16px #323232, centered at bottom (padding 208px 11px 0px)

const services = [
  { name: "Sector-Specific Security", active: true },
  { name: "Electronic Security Systems", active: false },
  { name: "Guarding Services", active: false },
  { name: "Support Services", active: false },
];

const tags = [
  "Event Security Services",
  "Construction Site Security",
  "Retail Security Services",
  "Corporate Security",
  "Public Sector Protection",
  "Care & Housing Security",
];
---

<section class="svc" id="services" aria-label="Comprehensive Security Services">
  <div class="svc__inner">
    <!-- ── Header ─────────────────────────────────────────── -->
    <div class="svc__header">
      <h2 class="svc__heading">Comprehensive Security Services</h2>
      <p class="svc__subheading">
        Delivering integrated security solutions across people, technology, and
        operations to protect what matters most.
      </p>
    </div>

    <!-- ── Body row ───────────────────────────────────────── -->
    <div class="svc__body">
      <!-- Left: label + service list -->
      <div class="svc__left">
        <span class="svc__label">WHAT WE OFFER</span>
        <div class="svc__list">
          {
            services.map((s) => (
              <a
                href="/services"
                class={`svc__row${s.active ? " svc__row--active" : ""}`}
              >
                <div class="svc__row-inner">
                  <div class="svc__icon-wrap">
                    <svg
                      width="24"
                      height="24"
                      viewBox="0 0 24 24"
                      fill="none"
                      aria-hidden="true"
                    >
                      <circle
                        cx="12"
                        cy="12"
                        r="10"
                        stroke="currentColor"
                        stroke-width="1.5"
                      />
                      <path
                        d="M12 8v4m0 4h.01"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                      />
                    </svg>
                  </div>
                  <span class="svc__row-name">{s.name}</span>
                  <svg
                    class="svc__row-arrow"
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    aria-hidden="true"
                  >
                    <path
                      d="M9 18l6-6-6-6"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                  </svg>
                </div>
                <div class="svc__row-divider" />
              </a>
            ))
          }
        </div>
      </div>

      <!-- Right: tag cards grid + CTA -->
      <div class="svc__right">
        <div class="svc__tags-wrap">
          <!-- Row 1: first 3 tags -->
          <div class="svc__tags-row">
            {tags.slice(0, 3).map((t) => <div class="svc__tag">{t}</div>)}
          </div>
          <!-- Row 2: last 3 tags -->
          <div class="svc__tags-row">
            {tags.slice(3).map((t) => <div class="svc__tag">{t}</div>)}
          </div>
        </div>
        <a href="/services" class="svc__cta">View All Services</a>
      </div>
    </div>
  </div>
</section>

<style>
  /* ── Section ────────────────────────────────────────────── */
  .svc {
    background-color: #ffffff;
    padding: 120px 64px 0;
  }

  .svc__inner {
    display: flex;
    flex-direction: column;
    gap: 32px;
    max-width: 1152px;
    margin: 0 auto;
    width: 100%;
  }

  /* ── Header ─────────────────────────────────────────────── */
  .svc__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    width: 100%;
  }

  .svc__heading {
    font-family: "Inter", sans-serif;
    font-weight: 600;
    font-size: 44px;
    line-height: 52px;
    letter-spacing: -0.0045em;
    color: #33587d;
    text-align: center;
    margin: 0;
  }

  .svc__subheading {
    font-family: "Inter", sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 26px;
    color: #323232;
    text-align: center;
    max-width: 700px;
    margin: 0;
  }

  /* ── Body row ────────────────────────────────────────────── */
  /* Figma: row, space-between */
  .svc__body {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: flex-start;
    width: 100%;
    gap: 0;
  }

  /* ── Left ───────────────────────────────────────────────── */
  /* Figma layout_OU0XIT: column, justifyContent center, hug sizing */
  .svc__left {
    display: flex;
    flex-direction: column;
    gap: 32px;
    flex-shrink: 0;
  }

  .svc__label {
    font-family: "Inter", sans-serif;
    font-weight: 500;
    font-size: 16px;
    line-height: 26px;
    color: #b61f26;
    display: block;
    text-align: left;
  }

  .svc__list {
    display: flex;
    flex-direction: column;
  }

  /* Figma layout_Q9HEE1: column, gap 40px, padding 40px 0 0 24px */
  .svc__row {
    display: flex;
    flex-direction: column;
    gap: 0;
    padding: 40px 0 0 24px;
    text-decoration: none;
    transition: opacity 180ms ease;
  }

  .svc__row:hover {
    opacity: 0.8;
  }

  /* Active: 4px red left border, adjust padding */
  .svc__row--active {
    border-left: 4px solid #b61f26;
    padding-left: 20px;
  }

  /* Row inner: row, center, gap 8px */
  .svc__row-inner {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 8px;
    width: 100%;
  }

  /* Icon pill 40×40, navy 15% bg */
  .svc__icon-wrap {
    width: 40px;
    height: 40px;
    border-radius: 9999px;
    background: rgba(51, 88, 125, 0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: #33587d;
  }

  .svc__row--active .svc__icon-wrap {
    background: rgba(51, 88, 125, 0.15);
    color: #33587d;
  }

  /* Service name: Inter Bold 700 16px */
  .svc__row-name {
    font-family: "Inter", sans-serif;
    font-weight: 700;
    font-size: 16px;
    line-height: 26px;
    color: #323232;
    flex: 1;
    text-align: left;
  }

  .svc__row--active .svc__row-name {
    color: #33587d;
  }

  .svc__row-arrow {
    color: #323232;
    flex-shrink: 0;
    opacity: 0.4;
  }

  /* Divider: Figma layout_Z51YQO: 315px × 0 (1px stroke) */
  .svc__row-divider {
    width: 315px;
    height: 1px;
    background: #eeeeee;
    margin-top: 40px;
  }

  /* ── Right ──────────────────────────────────────────────── */
  /* Figma layout_ZJXAYO: 753px fixed width, column gap 56px */
  .svc__right {
    display: flex;
    flex-direction: column;
    gap: 56px;
    width: 753px;
    flex-shrink: 0;
  }

  /* Tags container: column, gap 24px */
  .svc__tags-wrap {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  /* Each tag row: row, center, gap 24px */
  .svc__tags-row {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 24px;
  }

  /* Tag card: 235×280px, padding 208px 11px 0px (text at bottom)
     Background: gradient overlay ON TOP of cover image */
  .svc__tag {
    width: 235px;
    height: 280px;
    flex-shrink: 0;
    border-radius: 12px;
    box-shadow: 0px 4px 10px 0px rgba(0, 0, 0, 0.25);
    background:
      linear-gradient(180deg, rgba(102, 102, 102, 0) 70%, rgba(51, 88, 125, 1) 78%),
      url("/services/service-card-bg.png") center / cover no-repeat;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding: 0 11px 20px;
    font-family: "Inter", sans-serif;
    font-weight: 500;
    font-size: 16px;
    line-height: 26px;
    color: #ffffff;
    text-align: center;
    /* Figma text color is #323232 but that would be invisible on dark gradient — 
       the navy gradient overlay at bottom makes this white per visual spec */
  }

  /* ── CTA button ─────────────────────────────────────────── */
  /* Figma: row, center, gap 6px, padding 11px 16px, stroke 1.5px #B61F26, radius 12px */
  .svc__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 11px 16px;
    border: 1.5px solid #b61f26;
    border-radius: 12px;
    font-family: "Inter", sans-serif;
    font-weight: 700;
    font-size: 16px;
    line-height: 26px;
    color: #b61f26;
    text-decoration: none;
    width: fit-content;
    transition:
      background-color 180ms ease,
      color 180ms ease;
  }

  .svc__cta:hover {
    background-color: #b61f26;
    color: #ffffff;
  }

  /* ── Responsive ─────────────────────────────────────────── */
  @media (max-width: 1200px) {
    .svc__right {
      width: auto;
      flex: 1;
    }

    .svc__tags-row {
      flex-wrap: wrap;
    }
  }

  @media (max-width: 1100px) {
    .svc__body {
      flex-direction: column;
      gap: 48px;
    }
  }

  @media (max-width: 768px) {
    .svc {
      padding: 80px 32px 0;
    }

    .svc__heading {
      font-size: 32px;
      line-height: 40px;
    }

    .svc__tag {
      width: 180px;
      height: 220px;
    }

    .svc__row-divider {
      width: 100%;
    }
  }

  @media (max-width: 480px) {
    .svc {
      padding: 60px 20px 0;
    }

    .svc__tags-row {
      gap: 12px;
    }

    .svc__tag {
      width: 150px;
      height: 190px;
      font-size: 14px;
    }
  }
</style>
