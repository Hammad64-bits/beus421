---
// Service Section (1160:3964) — pixel perfect
// Figma structure:
//   padding: 120px 64px 0px | white bg
//   inner 1152px: column gap 32px
//     - Header: centered h2 + body
//     - Body row (space-between):
//         Left (layout_OU0XIT): column, hug — "WHAT WE OFFER" label + 4 service rows
//         Right (layout_ZJXAYO): 753px fixed, column gap 56px
//           - 2 rows of 3 tag cards (each row gap 24px, cards 235×280px)
//           - CTA button (red outline, "View All Services")
//
// Service row (layout_Q9HEE1): column, gap 40px, padding 40px 0 0 24px
//   - Icon pill 40×40 (navy 15% bg) + name (bold 700 16px) + arrow (24px)
// Service Section (1160:3964) — pixel perfect + dynamic tab switching

const services = [
  {
    id: "sector",
    name: "Sector-Specific Security",
    icon: "/vigilant_icons/Vector-9.svg",
    tags: [
      { name: "Event Security Services", image: "/services_images/event.png" },
      {
        name: "Construction Site Security",
        image: "/services_images/construction.png",
      },
      { name: "Retail Security Services", image: "/services_images/mall.png" },
      {
        name: "Corporate Security Services",
        image: "/services_images/bank.png",
      },
      {
        name: "Public Sector Protection",
        image: "/services_images/street.png",
      },
      { name: "Care & Housing Security", image: "/services_images/office.png" },
    ],
  },
  {
    id: "electronic",
    name: "Electronic Security Systems",
    icon: "/vigilant_icons/Vector-2.svg",
    tags: [
      { name: "CCTV & Surveillance", image: "/services_images/street.png" },
      { name: "Access Control Systems", image: "/services_images/office.png" },
      { name: "Intruder Alarm Systems", image: "/services_images/bank.png" },
      { name: "Fire Detection Systems", image: "/services_images/mall.png" },
      { name: "Intercom & Door Entry", image: "/services_images/event.png" },
      { name: "Remote Monitoring", image: "/services_images/construction.png" },
    ],
  },
  {
    id: "guarding",
    name: "Guarding Services",
    icon: "/vigilant_icons/Vector-14.svg",
    tags: [
      { name: "Manned Guarding", image: "/services_images/street.png" },
      { name: "Mobile Patrols", image: "/services_images/construction.png" },
      { name: "Reception Security", image: "/services_images/office.png" },
      { name: "Door Supervision", image: "/services_images/event.png" },
      { name: "Key Holding & Response", image: "/services_images/bank.png" },
      { name: "Alarm Response", image: "/services_images/mall.png" },
    ],
  },
  {
    id: "support",
    name: "Support Services",
    icon: "/vigilant_icons/Vector-6.svg",
    tags: [
      { name: "Cleaning Services", image: "/services_images/office.png" },
      { name: "Facilities Management", image: "/services_images/mall.png" },
      { name: "Concierge Services", image: "/services_images/bank.png" },
      {
        name: "Maintenance Support",
        image: "/services_images/construction.png",
      },
      { name: "Landscaping Services", image: "/services_images/street.png" },
      { name: "Waste Management", image: "/services_images/event.png" },
    ],
  },
];
---

<section class="svc" id="services" aria-label="Comprehensive Security Services">
  <div class="svc__inner">
    <!-- ── Header ─────────────────────────────────────────── -->
    <div class="svc__header">
      <h2 class="svc__heading">Comprehensive Security Services</h2>
      <p class="svc__subheading">
        Delivering integrated security solutions across people, technology, and
        operations to protect what matters most.
      </p>
    </div>
    <span class="svc__label">WHAT WE OFFER</span>
    <!-- ── Body row ───────────────────────────────────────── -->
    <div class="svc__body">
      <!-- Left: label + service list -->
      <div class="svc__left">
        <!-- <span class="svc__label">WHAT WE OFFER</span> -->
        <div class="svc__list">
          {
            services.map((s, i) => (
              <button
                class={`svc__row${i === 0 ? " svc__row--active" : ""}`}
                data-svc-id={s.id}
                aria-pressed={i === 0 ? "true" : "false"}
                type="button"
              >
                <div class="svc__row-inner">
                  <div class="svc__icon-wrap">
                    <img
                      src={s.icon}
                      alt=""
                      class="svc__icon-img"
                      aria-hidden="true"
                      width="24"
                      height="24"
                    />
                  </div>
                  <span class="svc__row-name">{s.name}</span>
                  <svg
                    class="svc__row-arrow"
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    aria-hidden="true"
                  >
                    <path
                      d="M9 18l6-6-6-6"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                  </svg>
                </div>
                <div class="svc__row-divider" />
              </button>
            ))
          }
        </div>
      </div>

      <!-- Right: tag panels (one per service, only active shown) + CTA -->
      <div class="svc__right">
        {
          services.map((s, i) => (
            <div
              class={`svc__panel${i === 0 ? " svc__panel--active" : ""}`}
              data-svc-panel={s.id}
              aria-hidden={i !== 0 ? "true" : "false"}
            >
              <div class="svc__tags-wrap">
                <div class="svc__tags-row">
                  {s.tags.slice(0, 3).map((t) => (
                    <div class="svc__tag">
                      <img src={t.image} alt="" class="svc__tag-img" aria-hidden="true" />
                      <div class="svc__tag-overlay" />
                      <span class="svc__tag-name">{t.name}</span>
                    </div>
                  ))}
                </div>
                <div class="svc__tags-row">
                  {s.tags.slice(3).map((t) => (
                    <div class="svc__tag">
                      <img src={t.image} alt="" class="svc__tag-img" aria-hidden="true" />
                      <div class="svc__tag-overlay" />
                      <span class="svc__tag-name">{t.name}</span>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          ))
        }
        <a href="/services" class="svc__cta">View All Services</a>
      </div>
    </div>
  </div>
</section>

<style>
  /* ── Section ────────────────────────────────────────────── */
  .svc {
    background-color: #ffffff;
    padding: 120px 64px 0;
  }

  .svc__inner {
    display: flex;
    flex-direction: column;
    gap: 32px;
    max-width: 1152px;
    margin: 0 auto;
    width: 100%;
  }

  /* ── Header ─────────────────────────────────────────────── */
  .svc__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    width: 100%;
  }

  .svc__heading {
    font-family: "Inter", sans-serif;
    font-weight: 600;
    font-size: 44px;
    line-height: 52px;
    letter-spacing: -0.0045em;
    color: #33587d;
    text-align: center;
    margin: 0;
  }

  .svc__subheading {
    font-family: "Inter", sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 26px;
    color: #323232;
    text-align: center;
    max-width: 700px;
    margin: 0;
  }

  /* ── Body row ────────────────────────────────────────────── */
  /* Figma: row, space-between */
  .svc__body {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: flex-start;
    width: 100%;
    gap: 0;
  }

  /* ── Left ───────────────────────────────────────────────── */
  /* Figma layout_OU0XIT: column, justifyContent center, hug sizing */
  .svc__left {
    display: flex;
    flex-direction: column;
    gap: 32px;
    flex-shrink: 0;
  }

  .svc__label {
    font-family: "Inter", sans-serif;
    font-weight: 500;
    font-size: 16px;
    line-height: 26px;
    color: #b61f26;
    display: block;
    text-align: left;
  }

  .svc__list {
    display: flex;
    flex-direction: column;
  }

  /* Button reset — .svc__row is now a <button> */
  .svc__row {
    display: flex;
    flex-direction: column;
    gap: 0;
    padding: 40px 0 0 24px;
    text-decoration: none;
    background: none;
    border: none;
    border-left: 4px solid transparent;
    cursor: pointer;
    width: 100%;
    text-align: left;
    transition:
      opacity 180ms ease,
      border-left 180ms ease;
  }

  .svc__row:hover {
    opacity: 0.85;
    border-left: 4px solid rgba(182, 31, 39, 0.15);
  }

  /* Active: 4px red left border, adjust padding */
  .svc__row--active {
    border-left: 4px solid #b61f26;
    padding-left: 20px;
  }

  /* Row inner: row, center, gap 8px */
  .svc__row-inner {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 8px;
    width: 100%;
  }

  /* Icon pill 40×40
     Default (inactive): subtle grey background
     Active: navy rgba(51,88,125,0.15) per Figma */
  .svc__icon-wrap {
    width: 40px;
    height: 40px;
    border-radius: 9999px;
    background: rgba(51, 88, 125, 0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: background 200ms ease;
  }

  /* Icon image inside the pill */
  .svc__icon-img {
    width: 20px;
    height: 20px;
    object-fit: contain;
    display: block;
    /* Default: dark icon, slightly muted */
    filter: opacity(0.5);
    transition: filter 200ms ease;
  }

  /* Active state: navy pill + vibrant navy-tinted icon */
  .svc__row--active .svc__icon-wrap {
    background: rgba(51, 88, 125, 0.15);
  }
  .svc__row--active .svc__icon-img {
    /* Shift icon to navy/blue tint — matches Figma active icon color #33587D */
    filter: brightness(0) saturate(100%) invert(33%) sepia(29%) saturate(700%)
      hue-rotate(175deg) brightness(90%) contrast(90%);
  }

  /* Service name: Inter Bold 700 16px */
  .svc__row-name {
    font-family: "Inter", sans-serif;
    font-weight: 700;
    font-size: 16px;
    line-height: 26px;
    color: #323232;
    flex: 1;
    text-align: left;
  }

  .svc__row--active .svc__row-name {
    color: #33587d;
  }

  .svc__row-arrow {
    color: #323232;
    flex-shrink: 0;
    opacity: 0.4;
  }

  /* Divider: Figma layout_Z51YQO: 315px × 0 (1px stroke) */
  .svc__row-divider {
    width: 315px;
    height: 1px;
    background: #eeeeee;
    margin-top: 40px;
  }

  /* ── Right ──────────────────────────────────────────────── */
  /* Figma layout_ZJXAYO: 753px fixed width, column gap 56px */
  .svc__right {
    display: flex;
    flex-direction: column;
    gap: 56px;
    width: 753px;
    flex-shrink: 0;
    /* Stack panels using CSS grid overlay — active panel shows, inactive hidden */
    position: relative;
  }

  /* Each panel: hidden by default, shown when active */
  .svc__panel {
    display: none;
    flex-direction: column;
    gap: 0;
    opacity: 0;
    transition: opacity 280ms ease;
  }
  .svc__panel--active {
    display: flex;
    opacity: 1;
  }

  /* Tags container: column, gap 24px */
  .svc__tags-wrap {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  /* Each tag row: row, center, gap 24px */
  .svc__tags-row {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 24px;
  }

  /* Tag card: 235×280px — overflow hidden clips the scaling image */
  .svc__tag {
    position: relative;
    width: 235px;
    height: 280px;
    flex-shrink: 0;
    border-radius: 12px;
    box-shadow: 0px 4px 10px 0px rgba(0, 0, 0, 0.25);
    overflow: hidden;
    cursor: pointer;
  }

  /* Cover image — scales on hover */
  .svc__tag-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transition: transform 500ms cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .svc__tag:hover .svc__tag-img {
    transform: scale(1.08);
  }

  /* Gradient overlay: transparent → dark at bottom */
  .svc__tag-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(50, 50, 50, 0) 50%, #000 100%);
    pointer-events: none;
  }

  /* Label pinned to bottom */
  .svc__tag-name {
    position: absolute;
    bottom: 20px;
    left: 0;
    right: 0;
    padding: 0 28px;
    font-family: "Inter", sans-serif;
    font-weight: 900;
    font-size: 18px;
    line-height: 28px;
    color: #ffffff;
    text-align: center;
    pointer-events: none;
  }

  /* ── CTA button ─────────────────────────────────────────── */
  /* Figma: row, center, gap 6px, padding 11px 16px, stroke 1.5px #B61F26, radius 12px */
  .svc__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 11px 16px;
    background-color: #b61f26;
    color: #ffffff;
    border-radius: 12px;
    font-family: "Inter", sans-serif;
    font-weight: 700;
    font-size: 16px;
    line-height: 26px;
    text-decoration: none;
    width: fit-content;
    transition:
      background-color 180ms ease,
      color 180ms ease;
  }

  .svc__cta:hover {
    background-color: #33587d;
    color: #ffffff;
  }

  /* ── Responsive ─────────────────────────────────────────── */
  @media (max-width: 1200px) {
    .svc__right {
      width: auto;
      flex: 1;
    }

    .svc__tags-row {
      flex-wrap: wrap;
    }
  }

  @media (max-width: 1100px) {
    .svc__body {
      flex-direction: column;
      gap: 48px;
    }
  }

  @media (max-width: 768px) {
    .svc {
      padding: 80px 32px 0;
    }

    .svc__heading {
      font-size: 32px;
      line-height: 40px;
    }

    .svc__tag {
      width: 180px;
      height: 220px;
    }

    .svc__row-divider {
      width: 100%;
    }
  }

  @media (max-width: 480px) {
    .svc {
      padding: 60px 20px 0;
    }

    .svc__tags-row {
      gap: 12px;
    }

    .svc__tag {
      width: 150px;
      height: 190px;
    }

    .svc__tag-name {
      font-size: 14px;
    }
  }
</style>

<script>
  import { gsap } from "gsap";

  const rows = document.querySelectorAll("[data-svc-id]");
  const panels = document.querySelectorAll("[data-svc-panel]");

  // Animate the cards inside a panel in with a stagger
  function animatePanel(panel: Element) {
    const tags = panel.querySelectorAll(".svc__tag");
    // Reset so they can re-animate even on re-click
    gsap.killTweensOf(tags);
    gsap.fromTo(
      tags,
      { y: 28, opacity: 0, scale: 0.94 },
      {
        y: 0,
        opacity: 1,
        scale: 1,
        duration: 0.45,
        stagger: 0.07,
        ease: "back.out(1.3)",
        clearProps: "transform",
      },
    );
  }

  rows.forEach((row) => {
    row.addEventListener("click", () => {
      const targetId = row.getAttribute("data-svc-id");

      // Deactivate all rows
      rows.forEach((r) => {
        r.classList.remove("svc__row--active");
        r.setAttribute("aria-pressed", "false");
      });

      // Activate clicked row
      row.classList.add("svc__row--active");
      row.setAttribute("aria-pressed", "true");

      // Swap panels + animate incoming cards
      panels.forEach((panel) => {
        if (panel.getAttribute("data-svc-panel") === targetId) {
          panel.classList.add("svc__panel--active");
          panel.setAttribute("aria-hidden", "false");
          animatePanel(panel);
        } else {
          panel.classList.remove("svc__panel--active");
          panel.setAttribute("aria-hidden", "true");
        }
      });
    });
  });

  // Run entrance animation on the initially active panel too
  const initialPanel = document.querySelector(".svc__panel--active");
  if (initialPanel) animatePanel(initialPanel);
</script>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  // Section header fades up
  gsap.from(".svc__header", {
    y: 40,
    opacity: 0,
    duration: 0.8,
    ease: "power3.out",
    scrollTrigger: {
      trigger: "#services",
      start: "top 80%",
      once: true,
    },
  });

  // Left service list slides in from left
  gsap.from(".svc__left", {
    x: -50,
    opacity: 0,
    duration: 0.9,
    ease: "power3.out",
    scrollTrigger: {
      trigger: ".svc__body",
      start: "top 80%",
      once: true,
    },
  });

  // Right panel slides in from right
  gsap.from(".svc__right", {
    x: 50,
    opacity: 0,
    duration: 0.9,
    ease: "power3.out",
    scrollTrigger: {
      trigger: ".svc__body",
      start: "top 80%",
      once: true,
    },
  });
</script>
