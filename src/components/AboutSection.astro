<style>
  /* ── Wrapper that positions corner arrows ──────────────────── */
  .about-wrapper {
    position: relative;
    /* Ensure the arrows clip to/near the section bounds */
    overflow: visible;
  }

  /* ── Corner arrow containers ───────────────────────────────── */
  .arrow-corner {
    position: absolute;
    width: 72px;
    height: 72px;
    z-index: 2;
    pointer-events: none;
  }

  /* Precise corner placement */
  .arrow-tl {
    top: 18px;
    left: 18px;
  }
  .arrow-tr {
    top: 18px;
    right: 18px;
  }
  .arrow-bl {
    bottom: 18px;
    left: 18px;
  }
  .arrow-br {
    bottom: 18px;
    right: 18px;
  }

  /* Both SVGs stacked absolutely within the corner box */
  .arrow-corner svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  /* Primary arrow: fully opaque */
  .arrow-primary {
    opacity: 0.25;
  }

  /* Shadow/duplicate arrow: slightly dimmer, offset via JS transform */
  .arrow-shadow {
    opacity: 0.1;
    /* Initial offset — JS will vary this on scroll */
    transform: translate(8px, 8px);
    transition: transform 0.05s linear;
  }

  /* ── Card style (unchanged) ────────────────────────────────── */
  .card {
    display: flex;
    flex-direction: column;
    align-items: start;
    justify-items: center;
    gap: 32px;
    max-width: 362px;
    height: 228px;
    border-radius: 24px;
    padding: 24px;
    background-color: #ffffff;
  }
</style>

<script>
  (function () {
    const wrapper = document.querySelector(".about-wrapper");
    if (!wrapper) return;

    const topCorners = wrapper.querySelectorAll("[data-arrow='top']");
    const bottomCorners = wrapper.querySelectorAll("[data-arrow='bottom']");

    // Parallax strength: max px the shadow shifts relative to primary
    const SHADOW_OFFSET = 12; // base gap between primary & shadow
    const PARALLAX_AMP = 10; // extra travel on scroll

    function update() {
      const rect = wrapper.getBoundingClientRect();
      const winH = window.innerHeight;

      // progress: -1 (section above viewport) → 0 (centred) → +1 (below viewport)
      const centre = rect.top + rect.height / 2 - winH / 2;
      const range = winH / 2 + rect.height / 2;
      const progress = Math.max(-1, Math.min(1, centre / range));

      // Top arrows: as we scroll down (progress < 0 → section moves up) shadow drifts further up
      const topShiftY = SHADOW_OFFSET - progress * PARALLAX_AMP; // grows as section rises
      const bottomShiftY = SHADOW_OFFSET + progress * PARALLAX_AMP; // grows as section falls

      topCorners.forEach((el) => {
        const shadow = el.querySelector(".arrow-shadow");
        if (shadow) shadow.style.transform = `translate(8px, ${-topShiftY}px)`;
      });

      bottomCorners.forEach((el) => {
        const shadow = el.querySelector(".arrow-shadow");
        if (shadow)
          shadow.style.transform = `translate(8px, ${bottomShiftY}px)`;
      });
    }

    window.addEventListener("scroll", update, { passive: true });
    window.addEventListener("resize", update, { passive: true });
    update(); // run once on load
  })();
</script>
