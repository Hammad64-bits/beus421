---
// our people / trust (710:1195)
// Figma: padding 120px 64px 0px, white bg, row layout, gap 100px
---

<section class="about" id="about" aria-label="About Vigilant Security">
  <div class="about__inner">
    <!-- Left: text content -->
    <div class="about__content">
      <!-- Heading block -->
      <div class="about__heading-block">
        <div class="about__heading-wrap">
          <h2 class="about__heading">
            FOUNDED IN 2006 ON<br />ABSOLUTE TRUST.
          </h2>
        </div>
        <div class="about__body-wrap">
          <p class="about__body">
            Vigilants Security was established with a singular mission: to
            redefine the standards of enterprise protection. Our methodology
            combines elite human intelligence with cutting-edge technological
            frameworks.
          </p>
        </div>
      </div>

      <!-- Two feature cards with red left border -->
      <div class="about__features">
        <!-- Card 1: Architectural Integrity -->
        <div class="about__feature-card">
          <div class="about__feature-inner">
            <h3 class="about__feature-title">ARCHITECTURAL INTEGRITY</h3>
            <p class="about__feature-body">
              Every security plan is structured like a building's
              foundation—designed to withstand immense pressure and evolving
              threats.
            </p>
          </div>
        </div>

        <!-- Card 2: Human Expertise -->
        <div class="about__feature-row">
          <div class="about__feature-inner">
            <h3 class="about__feature-title">HUMAN EXPERTISE</h3>
            <p class="about__feature-body">
              Our personnel are not just guards; they are tactical analysts
              trained to identify vulnerabilities before they manifest.
            </p>
          </div>
        </div>

        <!-- About Us CTA -->
        <a href="/about" class="about__btn">
          <img src="/vigilant_icons/Info.svg" alt="" />
          About Us
        </a>
      </div>
    </div>

    <!-- Right: person image with ambient shape bg -->
    <div class="about__img-frame">
      <!-- Round shape sitting behind the photo -->
      <div class="about__img-circle-2" aria-hidden="true"></div>
      <div class="about__img-circle" aria-hidden="true"></div>
      <!-- Thin red left-edge accent line -->
      <!-- <div class="about__img-stripe" aria-hidden="true"></div> -->
      <!-- The actual photo -->
      <div class="about__img-wrap">
        <img
          src="/hero/hero-person.png"
          alt="Vigilant Security officer"
          class="about__img"
        />
      </div>
    </div>
  </div>
</section>

<style>
  /* ── Section shell ──────────────────────────────────────── */
  .about {
    background-color: #ffffff;
    padding: 120px 64px 0;
    overflow: hidden;
  }

  /* ── Two-column row ─────────────────────────────────────── */
  .about__inner {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: center;
    gap: 100px;
    max-width: 1152px;
    margin: 0 auto;
    width: 100%;
  }

  /* ── Left column ─────────────────────────────────────────── */
  .about__content {
    display: flex;
    flex-direction: column;
    gap: 32px;
    width: 474px;
    flex-shrink: 0;
  }

  .about__heading-block {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .about__heading-wrap,
  .about__body-wrap {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    width: 100%;
  }

  .about__heading {
    font-family: "Inter", sans-serif;
    font-weight: 600;
    font-size: 44px;
    line-height: 52px;
    letter-spacing: -0.0045em;
    color: #33587d;
    margin: 0;
  }

  .about__body {
    font-family: "Inter", sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 26px;
    color: #323232;
    margin: 0;
  }

  /* ── Features block (left border accent) ────────────────── */
  .about__features {
    display: flex;
    flex-direction: column;
    gap: 56px;
    padding-left: 48px;
    border-left: 4px solid #b61f26;
    width: 438px;
    flex-shrink: 0;
  }

  .about__feature-card,
  .about__feature-row {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 8px;
    min-height: 99px;
  }

  .about__feature-inner {
    display: flex;
    flex-direction: column;
    gap: 8px;
    width: 100%;
  }

  .about__feature-title {
    font-family: "Inter", sans-serif;
    font-weight: 900;
    font-size: 18px;
    line-height: 28px;
    color: #33587d;
    margin: 0;
    text-transform: uppercase;
  }

  .about__feature-body {
    font-family: "Inter", sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 26px;
    color: #323232;
    margin: 0;
  }

  /* ── About Us button ─────────────────────────────────────── */
  .about__btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background-color: #b61f26;
    color: #ffffff;
    font-family: "Inter", sans-serif;
    font-weight: 700;
    font-size: 16px;
    line-height: 26px;
    padding: 10px 16px;
    border-radius: 12px;
    text-decoration: none;
    transition:
      opacity 180ms ease,
      transform 180ms ease,
      background-color 180 ease;
    width: fit-content;
  }

  .about__btn:hover {
    opacity: 0.88;
    transform: translateY(-1px);
    background-color: #33587d;
  }

  /* ── Right: image frame ──────────────────────────────── */
  .about__img-frame {
    position: relative;
    width: 480px;
    height: 480px;
    flex-shrink: 0;
  }

  /* Soft lavender decorative circle offset behind the photo */
  .about__img-circle {
    position: absolute;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    background: #cdd5e0;
    bottom: -28px;
    left: -28px;
    z-index: 0;
    pointer-events: none;
  }

  .about__img-circle-2 {
    position: absolute;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    background: #b61f26;
    bottom: -20px;
    left: -39px;
    z-index: 0;
    pointer-events: none;
  }

  /* Thin red left-edge accent — full height, 3px wide */
  .about__img-stripe {
    position: absolute;
    top: 0;
    left: 0;
    width: 3px;
    height: 100%;
    background: linear-gradient(180deg, #b61f26 0%, rgba(182, 31, 38, 0) 100%);
    z-index: 3;
    border-radius: 2px;
  }

  /* Photo container — circular clip */
  .about__img-wrap {
    position: absolute;
    top: 30px;
    left: -31px;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    overflow: hidden;
    z-index: 2;
  }

  .about__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  /* ── Responsive ─────────────────────────────────────────── */
  @media (max-width: 1200px) {
    .about__inner {
      gap: 60px;
    }

    .about__content {
      width: 420px;
    }

    .about__features {
      width: 380px;
    }

    .about__img-frame {
      width: 380px;
      height: 380px;
    }
  }

  @media (max-width: 960px) {
    .about {
      padding: 80px 32px 0;
    }

    .about__inner {
      flex-direction: column;
      gap: 48px;
      align-items: flex-start;
    }

    .about__content,
    .about__features {
      width: 100%;
    }

    .about__img-frame {
      width: 320px;
      height: 320px;
      align-self: center;
    }

    .about__heading {
      font-size: 36px;
      line-height: 44px;
    }
  }

  @media (max-width: 600px) {
    .about {
      padding: 60px 20px 0;
    }

    .about__features {
      padding-left: 24px;
    }

    .about__heading {
      font-size: 28px;
      line-height: 36px;
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  const aboutSection = document.querySelector("#about");
  const st: ScrollTrigger.Vars = {
    trigger: aboutSection,
    start: "top 75%",
    once: true,
  };

  // Left content: slide in from left
  gsap.from(".about__content", {
    x: -60,
    opacity: 0,
    duration: 0.9,
    ease: "power3.out",
    scrollTrigger: st,
  });

  // Circle shape swells in from nothing
  gsap.from(".about__img-circle", {
    scale: 0.5,
    opacity: 0,
    duration: 1.4,
    ease: "power2.out",
    transformOrigin: "center center",
    scrollTrigger: st,
  });

  // Red stripe draws downward (scaleY from top)
  gsap.from(".about__img-stripe", {
    scaleY: 0,
    opacity: 0,
    duration: 0.8,
    delay: 0.2,
    ease: "power3.out",
    transformOrigin: "top center",
    scrollTrigger: st,
  });

  // Photo slides in cleanly from the right
  gsap.from(".about__img-wrap", {
    x: 50,
    opacity: 0,
    duration: 1,
    delay: 0.15,
    ease: "power3.out",
    scrollTrigger: st,
  });

  // Feature cards stagger up
  gsap.from(".about__feature-card, .about__feature-row", {
    y: 30,
    opacity: 0,
    duration: 0.6,
    stagger: 0.15,
    ease: "power2.out",
    scrollTrigger: {
      trigger: ".about__features",
      start: "top 85%",
      once: true,
    },
  });

  // Button animates in separately — more forgiving trigger so it always fires
  gsap.from(".about__btn", {
    y: 20,
    opacity: 0,
    duration: 0.5,
    delay: 0.35,
    ease: "power2.out",
    scrollTrigger: {
      trigger: ".about__btn",
      start: "top 95%",
      once: true,
    },
  });
</script>
