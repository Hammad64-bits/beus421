---
const features = [
  {
    heading: "Rapid Deployment",
    subheading:
      "Sentry Units are quick to mobilise and ready to protect sites with minimal disruption to operations.",
  },
  {
    heading: "Flexible Coverage",
    subheading:
      "Ideal for short-term requirements, vacant properties, construction sites, and changing site conditions.",
  },
  {
    heading: "Monitored Protection",
    subheading:
      "Units provide an added layer of visibility and reassurance, backed by responsive on-site support.",
  },
];
---

<section class="cta-section" id="cta" aria-label="Get in touch">
  <div class="cta-inner">
    <div class="cta-left">
      <div class="cta-headings">
        <p class="cta-line1">Stronger Protection</p>
        <p class="cta-line2">
          Starts with the <span class="cta-accent">Right Partner</span>
        </p>
        <p class="cta-subtitle">
          Professional security solutions tailored to your business, property,
          and people — available when you need them most.
        </p>
      </div>
      <div class="cta-buttons">
        <a href="/contact" class="cta-btn cta-btn--red">
          <svg
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            aria-hidden="true"
            ><path
              d="M5 12H19M19 12L13 6M19 12L13 18"
              stroke="white"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"></path></svg
          >
          Quick Quote
        </a>
        <a href="/contact" class="cta-btn cta-btn--outline">
          <svg
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            aria-hidden="true"
            ><path
              d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 014.69 12a19.79 19.79 0 01-3.07-8.67A2 2 0 013.6 1.27h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L7.91 8.87a16 16 0 006 6l.96-.96a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"
              stroke="#33587D"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"></path></svg
          >
          Request Callback
        </a>
        <a href="/contact" class="cta-btn cta-btn--outline">
          <svg
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            aria-hidden="true"
            ><path
              d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 014.69 12a19.79 19.79 0 01-3.07-8.67A2 2 0 013.6 1.27h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L7.91 8.87a16 16 0 006 6l.96-.96a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"
              stroke="#33587D"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"></path></svg
          >
          Contact Us
        </a>
      </div>
    </div>
    <div class="cta-img-wrap">
      <div class="cta-fade cta-fade--left"></div>
      <div class="cta-fade cta-fade--right"></div>
      <img
        src="/partners/cta-bg.png"
        alt="Security personnel"
        class="cta-img"
      />
    </div>
  </div>
</section>

<style>
  .cta-section {
    background: #fff;
    padding: 120px 64px 90px;
  }
  .cta-inner {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    max-width: 1152px;
    margin: 0 auto;
    gap: 48px;
  }
  .cta-left {
    display: flex;
    flex-direction: column;
    gap: 72px;
    max-width: 669px;
    flex: 1;
  }
  .cta-headings {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }
  .cta-line1 {
    font-family: "Inter", sans-serif;
    font-weight: 600;
    font-size: 64px;
    line-height: 70px;
    letter-spacing: -0.0078em;
    color: #1a2040;
    margin: 0;
  }
  .cta-line2 {
    font-family: "Inter", sans-serif;
    font-weight: 600;
    font-size: 44px;
    line-height: 52px;
    letter-spacing: -0.0045em;
    color: #1a2040;
    margin: 0;
  }
  .cta-accent {
    color: #33587d;
  }
  .cta-subtitle {
    font-family: "Inter", sans-serif;
    font-weight: 700;
    font-size: 16px;
    line-height: 26px;
    color: #323232;
    margin: 0;
  }
  .cta-buttons {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
    padding-right: 32px;
  }
  .cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: "Inter", sans-serif;
    font-weight: 700;
    font-size: 16px;
    line-height: 26px;
    text-decoration: none;
    border-radius: 12px;
    transition:
      opacity 180ms ease,
      transform 180ms ease;
    white-space: nowrap;
  }
  .cta-btn:hover {
    opacity: 0.88;
    transform: translateY(-1px);
  }
  .cta-btn--red {
    background: #b61f26;
    color: #fff;
    padding: 10px 16px;
  }
  .cta-btn--red:hover {
    background: #33587d;
    color: #fff;
    padding: 10px 16px;
  }
  .cta-btn--outline {
    border: 1.5px solid #b61f26;
    color: #33587d;
    padding: 11px 16px;
  }
  .cta-btn--outline:hover {
    background: rgba(182, 31, 38, 0.06);
  }
  .cta-img-wrap {
    position: relative;
    width: 400px;
    flex-shrink: 0;
    height: 336px;
    overflow: hidden;
    border-radius: 16px;
  }
  .cta-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    opacity: 0.64;
  }
  .cta-fade {
    position: absolute;
    top: 8px;
    bottom: 8px;
    width: 134px;
    z-index: 1;
    pointer-events: none;
  }
  .cta-fade--left {
    left: 0;
    background: linear-gradient(90deg, #fff 0%, rgba(255, 255, 255, 0) 100%);
  }
  .cta-fade--right {
    right: 0;
    background: linear-gradient(270deg, #fff 0%, rgba(255, 255, 255, 0) 100%);
  }
  @media (max-width: 1100px) {
    .cta-inner {
      flex-direction: column;
      align-items: flex-start;
    }
    .cta-img-wrap {
      width: 100%;
      height: 260px;
    }
    .cta-left {
      gap: 40px;
      max-width: 100%;
    }
  }
  @media (max-width: 768px) {
    .cta-section {
      padding: 80px 32px 60px;
    }
    .cta-line1 {
      font-size: 44px;
      line-height: 52px;
    }
    .cta-line2 {
      font-size: 32px;
      line-height: 40px;
    }
    .cta-buttons {
      padding-right: 0;
    }
  }
  @media (max-width: 480px) {
    .cta-section {
      padding: 60px 20px 40px;
    }
    .cta-line1 {
      font-size: 36px;
      line-height: 44px;
    }
    .cta-btn {
      width: 100%;
      justify-content: center;
    }
    .cta-buttons {
      flex-direction: column;
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  // Headings fade up
  gsap.from(".cta-line1, .cta-line2, .cta-subtitle", {
    y: 36,
    opacity: 0,
    duration: 0.8,
    stagger: 0.14,
    ease: "power3.out",
    scrollTrigger: {
      trigger: "#cta",
      start: "top 78%",
      once: true,
    },
  });

  // Image slides in from right
  gsap.from(".cta-img-wrap", {
    x: 60,
    opacity: 0,
    duration: 1,
    ease: "power3.out",
    scrollTrigger: {
      trigger: "#cta",
      start: "top 78%",
      once: true,
    },
  });
</script>
