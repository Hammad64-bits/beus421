<style>
  /* ── Nav Menu ─────────────────────────────────────────────── */
  .nav-menu {
    display: flex;
    align-items: center;
    gap: 8px;
    height: 44px;
  }

  /* Each top-level nav item wrapper */
  .nav-item {
    position: relative;
    height: 44px;
    display: flex;
    align-items: center;
  }

  /* Links and trigger buttons share the same text style */
  .nav-link,
  .nav-dropdown-trigger {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 9px 4px;
    font-family: "Inter", sans-serif;
    font-size: 15px;
    font-weight: 400;
    color: var(--color-secondary);
    white-space: nowrap;
    cursor: pointer;
    transition: opacity 150ms ease;
  }

  .nav-link:hover,
  .nav-dropdown-trigger:hover {
    opacity: 0.8;
  }

  .nav-chevron {
    flex-shrink: 0;
    transition: transform 200ms ease;
  }

  .nav-dropdown:hover .nav-chevron {
    transform: rotate(180deg);
  }

  /* ── Dropdown Submenu ─────────────────────────────────────── */
  .nav-submenu {
    display: none;
    position: absolute;
    top: 44px;
    left: 0;
    width: 224px;
    background: #ffffff;
    border-radius: 12px;
    padding: 16px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12);
    z-index: 100;
    flex-direction: column;
    gap: 2px;
    margin-top: 8px;
  }

  /* Invisible bridge that fills the 8px gap so hover doesn't break */
  .nav-submenu::before {
    content: "";
    position: absolute;
    bottom: 100%;
    left: 0;
    right: 0;
    height: 8px;
  }

  /* show submenu on parent hover */
  .nav-dropdown:hover > .nav-submenu {
    display: flex;
  }

  /* ── Submenu Items ────────────────────────────────────────── */
  .nav-submenu-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 4px;
    width: 100%;
    padding: 4px 8px;
    border-radius: 12px;
    font-family: "Inter", sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: #1a2141;
    white-space: nowrap;
    cursor: pointer;
    transition: background-color 150ms ease;
    background: #ffffff;
  }

  .nav-submenu-item:hover {
    background-color: #f0f4fa;
  }

  /* ── Nested Flyout ────────────────────────────────────────── */
  .nav-nested-trigger {
    position: relative;
  }

  .nav-flyout {
    display: none;
    position: absolute;
    top: 0;
    left: calc(100% + 8px);
    width: auto;
  }

  .nav-nested-trigger:hover > .nav-flyout {
    display: flex;
  }

  /* bridge gap so the flyout stays open while moving cursor */
  .nav-flyout::before {
    content: "";
    position: absolute;
    top: 0;
    left: -8px;
    width: 8px;
    height: 100%;
  }

  /* ── Responsive Visibility Helpers ───────────────────────── */
  .mobile-controls {
    display: none;
  }
  .desktop-cta {
    display: block;
  }

  /* ── Mobile Sidebar ──────────────────────────────────────── */
  .sidebar-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    z-index: 199;
    opacity: 0;
    transition: opacity 300ms ease;
  }
  .sidebar-overlay.is-visible {
    display: block;
    opacity: 1;
  }

  .mobile-sidebar {
    position: fixed;
    top: 0;
    left: 0;
    width: min(320px, 85vw);
    height: 100dvh;
    background: var(--color-primary);
    z-index: 200;
    display: flex;
    flex-direction: column;
    transform: translateX(-100%);
    transition: transform 350ms cubic-bezier(0.4, 0, 0.2, 1);
    overflow-y: auto;
  }
  .mobile-sidebar.is-open {
    transform: translateX(0);
  }

  /* Sidebar header */
  .sidebar-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 20px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
  }
  .sidebar-logo {
    height: 44px;
    width: auto;
  }
  .sidebar-close-btn {
    color: #ffffff;
    cursor: pointer;
    padding: 6px;
    border-radius: 8px;
    transition: background 150ms ease;
  }
  .sidebar-close-btn:hover {
    background: rgba(255, 255, 255, 0.12);
  }

  /* Sidebar nav links */
  .sidebar-nav {
    flex: 1;
    display: flex;
    flex-direction: column;
    padding: 12px 0;
    overflow-y: auto;
  }
  .sidebar-link {
    display: block;
    padding: 13px 24px;
    font-family: "Inter", sans-serif;
    font-size: 15px;
    font-weight: 500;
    color: #ffffff;
    transition: background 150ms ease;
  }
  .sidebar-link:hover {
    background: rgba(255, 255, 255, 0.08);
  }

  /* Sidebar accordion */
  .sidebar-accordion-trigger {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 13px 24px;
    font-family: "Inter", sans-serif;
    font-size: 15px;
    font-weight: 500;
    color: #ffffff;
    cursor: pointer;
    transition: background 150ms ease;
  }
  .sidebar-accordion-trigger:hover {
    background: rgba(255, 255, 255, 0.08);
  }
  .sidebar-chevron {
    flex-shrink: 0;
    transition: transform 250ms ease;
  }
  .sidebar-accordion.is-open > .sidebar-accordion-trigger .sidebar-chevron {
    transform: rotate(180deg);
  }

  /* Accordion body: collapsed by default */
  .sidebar-accordion-body {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 300ms ease;
    overflow: hidden;
  }
  .sidebar-accordion.is-open > .sidebar-accordion-body {
    grid-template-rows: 1fr;
  }
  /* Inner wrapper needed for grid-template-rows animation trick */
  .sidebar-accordion-body > * {
    overflow: hidden;
    min-height: 0;
  }

  .sidebar-sub-link {
    display: block;
    padding: 10px 24px 10px 40px;
    font-family: "Inter", sans-serif;
    font-size: 14px;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.85);
    transition:
      background 150ms ease,
      color 150ms ease;
  }
  .sidebar-sub-link:hover {
    background: rgba(255, 255, 255, 0.08);
    color: #ffffff;
  }

  /* Nested accordion indentation */
  .sidebar-nested-accordion .sidebar-accordion-trigger {
    padding-left: 40px;
    font-size: 14px;
  }
  .sidebar-deep-link {
    padding-left: 56px;
  }

  /* Sidebar footer CTA */
  .sidebar-footer {
    padding: 20px;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
  }
  .sidebar-cta {
    width: 100%;
    justify-content: center;
  }

  /* ── Breakpoint: tablet / mobile (≤ 1024px) ─────────────── */
  @media (max-width: 1024px) {
    /* Hide banner entirely */
    .nav-banner {
      display: none;
    }

    /* Hide desktop nav + CTA */
    .nav-menu {
      display: none;
    }
    .desktop-cta {
      display: none;
    }

    /* Show mobile controls */
    .mobile-controls {
      display: flex;
      align-items: center;
      gap: 10px;
    }

    /* Tighten nav-bar padding on tablet/mobile */
    .nav-bar {
      padding: 12px 24px;
    }
  }

  /* ── Hamburger Button ────────────────────────────────────── */
  .hamburger-btn {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 36px;
    height: 36px;
    padding: 6px;
    cursor: pointer;
    border-radius: 8px;
    transition: background 150ms ease;
  }
  .hamburger-btn:hover {
    background: rgba(255, 255, 255, 0.12);
  }
  .bar {
    display: block;
    width: 100%;
    height: 2px;
    background: #ffffff;
    border-radius: 2px;
    transition:
      transform 300ms ease,
      opacity 300ms ease;
  }

  .nav-container {
    display: flex;
    flex-direction: column;
  }

  .nav-banner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 4px 64px;
    position: relative; /* needed for ::before pseudo-element */
    /* Figma gradient */
    background: linear-gradient(
      90.01deg,
      #2563eb 0.01%,
      #f97316 47.76%,
      #1a2040 88.66%
    );
    overflow: hidden;
  }

  /* Frosted-glass layer sits on top of the gradient */
  .nav-banner::before {
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(255, 255, 255, 0.08); /* subtle white sheen */
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    pointer-events: none; /* clicks pass through */
    z-index: 0;
  }

  /* Lift all direct children above the glass layer */
  .nav-banner > * {
    position: relative;
    z-index: 1;
  }

