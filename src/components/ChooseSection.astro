---
// Sector Section (741:2982)
// Figma: padding 120px 64px 0px, white bg
// Header centered, 4 portrait photo cards 264×469 with label at bottom

const sectors = [
  { label: "Retail", img: "/sectors/retail.png" },
  { label: "Education", img: "/sectors/education.png" },
  { label: "Construction", img: "/sectors/construction.png" },
  { label: "Corporate", img: "/sectors/corporate.png" },
];
---

<section class="sector" id="sectors" aria-label="Sectors we serve">
  <div class="sector__inner">
    <!-- Header -->
    <div class="sector__header">
      <h2 class="sector__heading">
        Specialized Solutions for<br />Complex Environments
      </h2>
      <p class="sector__body">
        Our extensive range of security services in the UK is designed to
        address the unique challenges faced by various sectors. Each service is
        delivered by thoroughly vetted, SIA-licensed security officers and
        backed by our commitment to professional excellence
      </p>
    </div>

    <!-- Photo cards row -->
    <div class="sector__cards">
      {
        sectors.map((s) => (
          <div class="sector__card">
            <img src={s.img} alt={s.label} class="sector__card-img" />
            <div class="sector__card-overlay" />
            <span class="sector__card-label">{s.label}</span>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  /* ── Section ────────────────────────────────────────────── */
  .sector {
    background-color: #ffffff;
    padding: 120px 64px 0;
  }

  .sector__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 64px;
    max-width: 1152px;
    margin: 0 auto;
    width: 100%;
  }

  /* ── Header ─────────────────────────────────────────────── */
  .sector__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    width: 100%;
  }

  .sector__heading {
    font-family: "Inter", sans-serif;
    font-weight: 600;
    font-size: 44px;
    line-height: 52px;
    letter-spacing: -0.0045em;
    color: #33587d;
    text-align: center;
    margin: 0;
  }

  .sector__body {
    font-family: "Inter", sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 26px;
    color: #323232;
    text-align: center;
    max-width: 800px;
    margin: 0;
  }

  /* ── Cards row ──────────────────────────────────────────── */
  .sector__cards {
    display: flex;
    align-items: flex-start;
    gap: 32px;
  }

  /* ── Single card ────────────────────────────────────────── */
  .sector__card {
    /* position: relative; */
    /* flex: 1; */
    /* min-width: 150px; */
    width: 264px;
    height: 469px;
    border-radius: 12px;
    overflow: hidden;
    cursor: pointer;
    transition: transform 220ms cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .sector__card:hover {
    transform: translateY(-6px);
  }

  .sector__card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transition: transform 500ms cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .sector__card:hover .sector__card-img {
    transform: scale(1.08);
  }

  /* gradient overlay: transparent → dark at bottom */
  .sector__card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0) 0%,
      rgba(0, 0, 0, 0.3) 100%
    );
    pointer-events: none;
  }

  /* Label at bottom of card */
  .sector__card-label {
    position: absolute;
    bottom: 36px;
    left: 0;
    right: 0;
    text-align: center;
    font-family: "Inter", sans-serif;
    font-weight: 900;
    font-size: 32px;
    line-height: 36px;
    letter-spacing: 0.0156em;
    color: #ffffff;
    pointer-events: none;
  }

  /* ── Responsive ─────────────────────────────────────────── */
  @media (max-width: 1100px) {
    .sector__cards {
      flex-wrap: wrap;
      gap: 24px;
    }
  }

  @media (max-width: 768px) {
    .sector {
      padding: 80px 32px 0;
    }

    .sector__heading {
      font-size: 32px;
      line-height: 40px;
    }

    .sector__card {
      width: 220px;
      height: 380px;
    }

    .sector__card-label {
      font-size: 24px;
      bottom: 24px;
    }
  }

  @media (max-width: 540px) {
    .sector {
      padding: 60px 20px 0;
    }

    .sector__cards {
      gap: 16px;
    }

    .sector__card {
      width: 150px;
      height: 280px;
    }

    .sector__card-label {
      font-size: 18px;
      bottom: 16px;
    }
  }
</style>
<style>
  /* ── Scroll-reveal base states ── */
  .sector__header,
  .sector__card {
    opacity: 0;
    transform: translateY(40px);
    transition:
      opacity 0.7s ease,
      transform 0.7s ease;
  }

  .sector__header.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .sector__card.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const header = document.querySelector(".sector__header");
  const cards = document.querySelectorAll(".sector__card");

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("is-visible");
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.15 }
  );

  if (header) observer.observe(header);

  cards.forEach((card, i) => {
    (card as HTMLElement).style.transitionDelay = `${i * 0.1}s`;
    observer.observe(card);
  });
</script>
